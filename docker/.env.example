# How to use this .env file

# To use this file, you just have to define your home instance below and inject .env file via compose.yaml as shown in the compose.yaml example

# Instance to lock the client to (no instance input field shown on the login screen).
# Leave empty or remove this line to allow users to log in to any instance.
# SINGLE_INSTANCE=social.ztfr.eu

# Host port the container listens on (default: 80)
# PORT=80

# Default language settings
# LOCALE=en-US

# Translation API base URL (LibreTranslate-compatible instance).
# Defaults to the public libretranslate.com instance (rate-limited, no API key required).
# Self-hosted LibreTranslate is recommended for production use.
# See https://libretranslate.com for a list of public instances.
# TRANSLATE_API=https://your-libretranslate-instance.example.com
