# How to use this .env file

# Instance to lock the client to (no instance input field shown on the login screen).
# To use this file, you just have to define your home instance and rename it to .env and leave it at this root directory
# Leave empty or remove this line to allow users to log in to any instance.
# SINGLE_INSTANCE=social.ztfr.eu

# Host port the container listens on (default: 80)
# PORT=80
